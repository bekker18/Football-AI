# --- project data & artifacts (large / generated) ---
# Keep the folders (Docker bind mounts need them) but ignore their contents.
# Outputs now land in data/gamestate/ (one mount for everything).
data/*
!data/.gitkeep
!data/raw/
data/raw/*
!data/raw/.gitkeep
!data/gamestate/
data/gamestate/*
!data/gamestate/.gitkeep

*.pt              # YOLO checkpoints
*.mp4             # videos
*.avi
*.mov
*.mkv
hf_cache/         # SigLIP weights cache

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp