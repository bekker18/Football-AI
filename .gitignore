# --- project data & artifacts (large / generated) ---
# Keep the folders (Docker bind mounts need them) but ignore their contents.
data/*
output/*
!data/.gitkeep
!output/.gitkeep

*.pt              # YOLO checkpoints
*.mp4             # videos
*.avi
*.mov
*.mkv
hf_cache/         # SigLIP weights cache

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp